{
  "schemaVersion": "1",
  "kind": "channel",
  "name": "telegram",
  "displayName": "Telegram",
  "network": ["api.telegram.org"],
  "secrets": [
    { "ref": "telegram_bot", "description": "Telegram bot token from @BotFather; injected by the sbx proxy." }
  ],
  "env": {},
  "config": {
    "role": "messaging-channel",
    "transport": "telegram",
    "auth": { "type": "botToken", "secretRef": "telegram_bot", "envVar": "TELEGRAM_BOT_TOKEN" }
  }
}
