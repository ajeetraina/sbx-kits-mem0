{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sbx.dev/schemas/agent-context-1.json",
  "title": "agent-context fragment",
  "description": "Written by a provider or channel kit at BUILD time into /etc/sbx/agent-context.d/<name>.json. The agent kit reads every fragment at STARTUP and configures itself accordingly. This file IS the contract that makes provider/channel kits reusable across agents.",
  "type": "object",
  "required": ["schemaVersion", "kind", "name", "config"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1" },
    "kind": { "enum": ["provider", "channel"] },
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "displayName": { "type": "string" },
    "network": {
      "type": "array",
      "description": "Domains this kit opened. Informational: build mode / the proxy can audit exactly this set.",
      "items": { "type": "string" }
    },
    "secrets": {
      "type": "array",
      "description": "Secrets the kit needs, as REFS only. The sbx proxy resolves the ref to a value at runtime; values never appear in a fragment.",
      "items": {
        "type": "object",
        "required": ["ref"],
        "not": { "required": ["value"] },
        "properties": {
          "ref": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "env": {
      "type": "object",
      "description": "Env vars the agent should ensure are exported.",
      "additionalProperties": { "type": "string" }
    },
    "config": {
      "type": "object",
      "required": ["role"],
      "properties": {
        "role": { "enum": ["llm-provider", "messaging-channel"] }
      },
      "oneOf": [
        {
          "title": "provider config",
          "required": ["role", "apiStyle", "baseUrl", "auth", "models"],
          "properties": {
            "role": { "const": "llm-provider" },
            "apiStyle": { "enum": ["openai-compatible", "gemini"] },
            "baseUrl": { "type": "string" },
            "auth": { "$ref": "#/$defs/auth" },
            "models": {
              "type": "object",
              "required": ["llm", "embedder"],
              "properties": {
                "llm": { "type": "string" },
                "embedder": { "type": "string" }
              }
            }
          }
        },
        {
          "title": "channel config",
          "required": ["role", "transport", "auth"],
          "properties": {
            "role": { "const": "messaging-channel" },
            "transport": { "type": "string" },
            "auth": { "$ref": "#/$defs/auth" }
          }
        }
      ]
    }
  },
  "$defs": {
    "auth": {
      "type": "object",
      "required": ["type", "secretRef"],
      "properties": {
        "type": { "enum": ["apiKey", "botToken", "oauth"] },
        "secretRef": { "type": "string" },
        "envVar": { "type": "string" }
      }
    }
  }
}
