{
  "schemaVersion": "1",
  "kind": "provider",
  "name": "openai",
  "displayName": "OpenAI",
  "network": ["api.openai.com"],
  "secrets": [
    { "ref": "openai", "description": "OpenAI API key; injected by the sbx proxy, never present in the sandbox." }
  ],
  "env": { "OPENAI_BASE_URL": "https://api.openai.com/v1" },
  "config": {
    "role": "llm-provider",
    "apiStyle": "openai-compatible",
    "baseUrl": "https://api.openai.com/v1",
    "auth": { "type": "apiKey", "secretRef": "openai", "envVar": "OPENAI_API_KEY" },
    "models": { "llm": "gpt-4o-mini", "embedder": "text-embedding-3-small" }
  }
}
